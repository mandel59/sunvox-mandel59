{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mandel59.github.io/sunvox-mandel59/sunvox-db.schema.json",
  "title": "SunVox codec knowledge database",
  "type": "object",
  "required": ["version", "chunks", "enums", "bitfields", "grammar", "moduleDataChunkGrammar", "runtimeConstraints", "modules"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 4, "maxLength": 4 },
          "scope": { "enum": ["project", "pattern", "module"] },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "label": { "type": "string" },
          "sourceType": { "enum": ["int32", "uint32", "uint16", "uint8", "int8", "bytes", "string", "container", "empty"] },
          "valueKind": {
            "enum": ["bitset", "bytes", "color", "controller", "count", "enum", "events", "flags", "grid", "icon", "index", "level", "linkSlots", "links", "midi", "position", "rate", "scale", "state", "tempo", "terminator", "text", "version"]
          },
          "sourceSymbol": { "type": "string" },
          "signedRoundTrip": { "type": "boolean" },
          "linkSlots": {
            "type": "object",
            "required": ["linkChunk", "localLinksPath", "semanticPath", "slotCountPath"],
            "properties": {
              "linkChunk": { "type": "string", "minLength": 4, "maxLength": 4 },
              "localLinksPath": { "type": "string" },
              "remoteLinksPath": { "type": "string" },
              "semanticPath": { "type": "string" },
              "slotCountPath": { "type": "string" },
              "slotSide": { "type": "string" },
              "default": { "type": "integer" },
              "omittedWhenAllSlotsNonPositive": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "enums": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "bitfields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "fields"],
        "properties": {
          "type": { "enum": ["uint8", "uint32"] },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "shift", "bits"],
              "properties": {
                "name": { "type": "string" },
                "shift": { "type": "integer", "minimum": 0 },
                "bits": { "type": "integer", "minimum": 1, "maximum": 32 },
                "enum": { "type": "string" },
                "bitflags": { "type": "string" },
                "default": {}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "bitflags": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "bit"],
          "properties": {
            "name": { "type": "string" },
            "bit": { "type": "integer", "minimum": 0, "maximum": 31 }
          },
          "additionalProperties": false
        }
      }
    },
    "structs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["recordSize", "fields"],
        "properties": {
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "recordSize": { "type": "integer", "minimum": 1 },
          "textLayout": {
            "type": "object",
            "required": ["kind", "path", "tupleFields"],
            "properties": {
              "kind": { "enum": ["lineMajorTupleArray", "sparsePatternEvents"] },
              "path": { "type": "string" },
              "columnsPath": { "type": "string" },
              "rowsPath": { "type": "string" },
              "columnsOverridePath": { "type": "string" },
              "rowsOverridePath": { "type": "string" },
              "positionFields": {
                "type": "array",
                "items": { "type": "string" }
              },
              "tupleFields": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "emptyTuple": {
                "type": "array",
                "items": { "type": "integer" }
              },
              "fieldSemantics": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "description": { "type": "string" },
                    "encoding": { "type": "string" },
                    "reference": { "type": "string" },
                    "zero": { "type": "string" },
                    "range": { "type": "string" },
                    "aliases": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "packedFields": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["name", "shift", "bits"],
                        "properties": {
                          "name": { "type": "string" },
                          "shift": { "type": "integer", "minimum": 0 },
                          "bits": { "type": "integer", "minimum": 1, "maximum": 31 },
                          "offset": { "type": "integer" },
                          "min": { "type": "integer" },
                          "max": { "type": "integer" },
                          "reference": { "type": "string" }
                        },
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type", "offset"],
              "properties": {
                "name": { "type": "string" },
                "type": { "enum": ["bool8", "int32", "uint8", "uint16", "uint32"] },
                "offset": { "type": "integer", "minimum": 0 },
                "count": { "type": "integer", "minimum": 1 },
                "default": {},
                "invert": { "type": "boolean" },
                "enum": { "type": "string" },
                "bitfield": { "type": "string" },
                "bitflags": { "type": "string" },
                "flatten": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "grammar": {
      "type": "object",
      "required": ["scopes"],
      "properties": {
        "scopes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["fields", "order"],
            "properties": {
              "terminator": { "type": "string", "minLength": 4, "maxLength": 4 },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["chunk", "path", "field"],
                  "properties": {
                    "chunk": { "type": "string", "minLength": 4, "maxLength": 4 },
                    "path": { "type": "string" },
                    "field": { "enum": ["value", "text", "rgb", "values", "base64", "pattern.events"] },
                    "enum": { "type": "string" },
                    "bitfield": { "type": "string" },
                    "bitflags": { "type": "string" },
                    "omitDefaults": { "type": "boolean" },
                    "textSize": { "type": "integer", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "order": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "moduleDataChunkGrammar": {
      "type": "object",
      "required": ["path", "countPath", "countChunk", "indexChunk", "payloadChunk", "metadataChunks"],
      "properties": {
        "path": { "type": "string" },
        "countPath": { "type": "string" },
        "countChunk": { "type": "string", "minLength": 4, "maxLength": 4 },
        "indexChunk": { "type": "string", "minLength": 4, "maxLength": 4 },
        "payloadChunk": { "type": "string", "minLength": 4, "maxLength": 4 },
        "metadataChunks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["chunk", "path", "field"],
            "properties": {
              "chunk": { "type": "string", "minLength": 4, "maxLength": 4 },
              "path": { "type": "string" },
              "kind": { "type": "string" },
              "field": { "enum": ["value", "text", "rgb", "values", "base64"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "runtimeConstraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "scope", "path", "kind", "severity", "description"],
        "properties": {
          "id": { "type": "string" },
          "scope": { "enum": ["project", "module", "moduleLink"] },
          "path": { "type": "string" },
          "relation": { "type": "string" },
          "kind": { "enum": ["integerRange", "maxUtf8Bytes"] },
          "min": { "type": "integer" },
          "max": { "type": "integer" },
          "maxBytes": { "type": "integer", "minimum": 0 },
          "severity": { "enum": ["warning", "error"] },
          "source": { "type": "string" },
          "trackingIssue": { "type": "integer", "minimum": 1 },
          "observedBehavior": {
            "type": "object",
            "required": ["probeValue", "savedValue"],
            "properties": {
              "probeValue": {},
              "loadedValue": {},
              "savedValue": {},
              "description": { "type": "string" }
            },
            "additionalProperties": false
          },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "inputs": { "type": "integer", "minimum": 0 },
          "outputs": { "type": "integer", "minimum": 0 },
          "flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "flags2": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dataChunks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["index", "name", "type"],
              "properties": {
                "index": { "type": "integer", "minimum": 0 },
                "name": { "type": "string" },
                "type": { "enum": ["bytes", "container", "int8Array", "packedUInt32Array", "recordArray", "samplerEnvelope", "string", "struct", "uint8Array", "uint16Array"] },
                "sourceType": { "enum": ["int32", "uint32", "uint16", "uint8", "int8", "bytes", "string", "container", "empty"] },
                "valueKind": {
                  "enum": ["container", "controllerLinks", "curve", "envelope", "harmonics", "instrument", "mapping", "options", "sample", "sampleData", "slots", "text", "waveform"]
                },
                "sourceSymbol": { "type": "string" },
                "path": { "type": "string" },
                "count": { "type": "integer", "minimum": 0 },
                "size": { "type": "integer", "minimum": 0 },
                "headerSize": { "type": "integer", "minimum": 0 },
                "recordSize": { "type": "integer", "minimum": 0 },
                "format": { "type": "string" },
                "omitZero": { "type": "boolean" },
                "omitDefaults": { "type": "boolean" },
                "omitDefaultRecords": { "type": "boolean" },
                "trimTrailingZeroes": { "type": "boolean" },
                "flagBitfield": { "type": "string" },
                "flagBitflags": { "type": "string" },
                "magic": {
                  "type": "array",
                  "items": { "enum": ["SVOX", "SSYN"] }
                },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "enum": ["bool8", "fixedString", "int8", "int32", "uint8", "uint16", "uint32"] },
                      "offset": { "type": "integer", "minimum": 0 },
                      "count": { "type": "integer", "minimum": 1 },
                      "default": {},
                      "invert": { "type": "boolean" },
                      "enum": { "type": "string" },
                      "bitfield": { "type": "string" },
                      "bitflags": { "type": "string" },
                      "flatten": { "type": "boolean" },
                      "shift": { "type": "integer", "minimum": 0 },
                      "bits": { "type": "integer", "minimum": 1, "maximum": 32 }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "dataChunkRanges": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start", "end", "name", "type"],
              "properties": {
                "start": { "type": "integer", "minimum": 0 },
                "end": { "type": "integer", "minimum": 0 },
                "name": { "type": "string" },
                "type": { "enum": ["bytes", "container", "int8Array", "packedUInt32Array", "recordArray", "samplerEnvelope", "string", "struct", "uint8Array", "uint16Array"] },
                "sourceType": { "enum": ["int32", "uint32", "uint16", "uint8", "int8", "bytes", "string", "container", "empty"] },
                "valueKind": {
                  "enum": ["container", "controllerLinks", "curve", "envelope", "harmonics", "instrument", "mapping", "options", "sample", "sampleData", "slots", "text", "waveform"]
                },
                "sourceSymbol": { "type": "string" },
                "path": { "type": "string" },
                "step": { "type": "integer", "minimum": 1 },
                "count": { "type": "integer", "minimum": 0 },
                "size": { "type": "integer", "minimum": 0 },
                "headerSize": { "type": "integer", "minimum": 0 },
                "recordSize": { "type": "integer", "minimum": 0 },
                "format": { "type": "string" },
                "omitZero": { "type": "boolean" },
                "omitDefaults": { "type": "boolean" },
                "omitDefaultRecords": { "type": "boolean" },
                "trimTrailingZeroes": { "type": "boolean" },
                "flagBitfield": { "type": "string" },
                "flagBitflags": { "type": "string" },
                "magic": {
                  "type": "array",
                  "items": { "enum": ["SVOX", "SSYN"] }
                },
                "indexOffset": { "type": "integer", "minimum": 0 },
                "indexDivisor": { "type": "integer", "minimum": 1 },
                "indexName": { "type": "string" },
                "indexEnum": { "type": "string" },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "enum": ["bool8", "fixedString", "int8", "int32", "uint8", "uint16", "uint32"] },
                      "offset": { "type": "integer", "minimum": 0 },
                      "count": { "type": "integer", "minimum": 1 },
                      "default": {},
                      "invert": { "type": "boolean" },
                      "enum": { "type": "string" },
                      "bitfield": { "type": "string" },
                      "bitflags": { "type": "string" },
                      "flatten": { "type": "boolean" },
                      "shift": { "type": "integer", "minimum": 0 },
                      "bits": { "type": "integer", "minimum": 1, "maximum": 32 }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "controllers": {
            "type": "array",
            "items": {
              "type": "object",
              "anyOf": [{ "required": ["index", "name", "type"] }, { "required": ["repeat"] }],
              "properties": {
                "index": { "type": "integer", "minimum": 0 },
                "name": { "type": "string" },
                "path": { "type": "string" },
                "label": { "type": "string" },
                "type": { "enum": ["int32", "enum"] },
                "enum": { "type": "string" },
                "min": { "type": "integer" },
                "max": { "type": "integer" },
                "default": { "type": "integer" },
                "normal": { "type": "integer" },
                "group": { "type": "integer" },
                "dynamicLimits": {
                  "type": "object",
                  "required": ["controller"],
                  "properties": {
                    "controller": { "type": "string" },
                    "source": { "type": "string" },
                    "default": {
                      "type": "object",
                      "properties": {
                        "min": { "type": "integer" },
                        "max": { "type": "integer" }
                      },
                      "additionalProperties": false
                    },
                    "cases": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "min": { "type": "integer" },
                          "max": { "type": "integer" }
                        },
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                },
                "repeat": {
                  "type": "object",
                  "required": ["count", "startIndex", "items"],
                  "properties": {
                    "count": { "type": "integer", "minimum": 1 },
                    "startIndex": { "type": "integer", "minimum": 0 },
                    "idTemplate": { "type": "string" },
                    "pathTemplate": { "type": "string" },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["name", "type"],
                        "properties": {
                          "name": { "type": "string" },
                          "label": { "type": "string" },
                          "type": { "enum": ["int32", "enum"] },
                          "enum": { "type": "string" },
                          "min": {},
                          "max": {},
                          "default": {},
                          "normal": {},
                          "group": {},
                          "unit": { "type": "string" },
                          "scale": { "type": "string" },
                          "displayOffset": {},
                          "repeatCount": { "type": "integer", "minimum": 1 },
                          "pathTemplate": { "type": "string" },
                          "idTemplate": { "type": "string" }
                        },
                        "additionalProperties": true
                      }
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
