{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mandel59.github.io/sunvox-mandel59/sunvox-db.schema.json",
  "title": "SunVox codec knowledge database",
  "type": "object",
  "required": ["version", "chunks", "enums", "bitfields", "grammar", "modules"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 4, "maxLength": 4 },
          "scope": { "enum": ["project", "pattern", "module"] },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "label": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "enums": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "bitfields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "fields"],
        "properties": {
          "type": { "enum": ["uint32"] },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "shift", "bits"],
              "properties": {
                "name": { "type": "string" },
                "shift": { "type": "integer", "minimum": 0 },
                "bits": { "type": "integer", "minimum": 1, "maximum": 32 },
                "enum": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "bitflags": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "bit"],
          "properties": {
            "name": { "type": "string" },
            "bit": { "type": "integer", "minimum": 0, "maximum": 31 }
          },
          "additionalProperties": false
        }
      }
    },
    "structs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["recordSize", "fields"],
        "properties": {
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "recordSize": { "type": "integer", "minimum": 1 },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type", "offset"],
              "properties": {
                "name": { "type": "string" },
                "type": { "enum": ["bool8", "int32", "uint8", "uint16", "uint32"] },
                "offset": { "type": "integer", "minimum": 0 },
                "count": { "type": "integer", "minimum": 1 },
                "default": {},
                "invert": { "type": "boolean" },
                "enum": { "type": "string" },
                "bitfield": { "type": "string" },
                "bitflags": { "type": "string" },
                "flatten": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "grammar": {
      "type": "object",
      "required": ["scopes"],
      "properties": {
        "scopes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["fields", "order"],
            "properties": {
              "terminator": { "type": "string", "minLength": 4, "maxLength": 4 },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["chunk", "path", "field"],
                  "properties": {
                    "chunk": { "type": "string", "minLength": 4, "maxLength": 4 },
                    "path": { "type": "string" },
                    "field": { "enum": ["value", "text", "rgb", "values", "base64", "pattern.events"] },
                    "bitflags": { "type": "string" },
                    "textSize": { "type": "integer", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "order": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "modules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "dataChunks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["index", "name", "type"],
              "properties": {
                "index": { "type": "integer", "minimum": 0 },
                "name": { "type": "string" },
                "type": { "enum": ["container", "packedUInt32Array", "recordArray", "string", "struct", "uint8Array", "uint16Array"] },
                "path": { "type": "string" },
                "count": { "type": "integer", "minimum": 0 },
                "size": { "type": "integer", "minimum": 0 },
                "recordSize": { "type": "integer", "minimum": 0 },
                "format": { "type": "string" },
                "omitZero": { "type": "boolean" },
                "omitDefaults": { "type": "boolean" },
                "omitDefaultRecords": { "type": "boolean" },
                "magic": {
                  "type": "array",
                  "items": { "enum": ["SVOX", "SSYN"] }
                },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "enum": ["bool8", "int32", "uint8", "uint16", "uint32"] },
                      "offset": { "type": "integer", "minimum": 0 },
                      "count": { "type": "integer", "minimum": 1 },
                      "default": {},
                      "invert": { "type": "boolean" },
                      "enum": { "type": "string" },
                      "bitfield": { "type": "string" },
                      "bitflags": { "type": "string" },
                      "flatten": { "type": "boolean" },
                      "shift": { "type": "integer", "minimum": 0 },
                      "bits": { "type": "integer", "minimum": 1, "maximum": 32 }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "dataChunkRanges": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start", "end", "name", "type"],
              "properties": {
                "start": { "type": "integer", "minimum": 0 },
                "end": { "type": "integer", "minimum": 0 },
                "name": { "type": "string" },
                "type": { "enum": ["string"] },
                "format": { "type": "string" },
                "indexOffset": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "controllers": {
            "type": "array",
            "items": {
              "type": "object",
              "anyOf": [{ "required": ["index", "name", "type"] }, { "required": ["repeat"] }],
              "properties": {
                "index": { "type": "integer", "minimum": 0 },
                "name": { "type": "string" },
                "path": { "type": "string" },
                "label": { "type": "string" },
                "type": { "enum": ["int32", "enum"] },
                "enum": { "type": "string" },
                "min": { "type": "integer" },
                "max": { "type": "integer" },
                "default": { "type": "integer" },
                "normal": { "type": "integer" },
                "group": { "type": "integer" },
                "repeat": {
                  "type": "object",
                  "required": ["count", "startIndex", "items"],
                  "properties": {
                    "count": { "type": "integer", "minimum": 1 },
                    "startIndex": { "type": "integer", "minimum": 0 },
                    "idTemplate": { "type": "string" },
                    "pathTemplate": { "type": "string" },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["name", "type"],
                        "properties": {
                          "name": { "type": "string" },
                          "label": { "type": "string" },
                          "type": { "enum": ["int32", "enum"] },
                          "enum": { "type": "string" },
                          "min": {},
                          "max": {},
                          "default": {},
                          "normal": {},
                          "group": {},
                          "unit": { "type": "string" },
                          "scale": { "type": "string" },
                          "displayOffset": {},
                          "repeatCount": { "type": "integer", "minimum": 1 },
                          "pathTemplate": { "type": "string" },
                          "idTemplate": { "type": "string" }
                        },
                        "additionalProperties": true
                      }
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
